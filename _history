w></value></block></statement><statement name=\"ELSE\"><block type=\"gameSplash\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" _expanded=\"0\" _input_init=\"true\"></mutation><value name=\"title\"><shadow type=\"text\"><field name=\"TEXT\">Burayla işin yok!</field></shadow></value></block></statement></block></next></block></next></block></next></block></next></block></statement></block></xml>","main.ts":"","README.md":" ","assets.json":"","main.py":"# ─────────────────────────────────────────\n# TILE DEĞİŞİKLİKLERİNİ KAYDETME SİSTEMİ\n# ─────────────────────────────────────────\n# MakeCode dict desteklemediği için iki paralel liste kullanıyoruz:\n#   saved_x[i], saved_y[i]  → tile konumu\n#   saved_tiles[i]          → o konuma yerleştirilen tile görseli\nsaved_x = []\nsaved_y = []\nsaved_tiles = []\n\ndef save_tile_change(tx, ty, tile_image):\n    \"\"\"Bir tile değişikliğini kaydeder. Aynı konum zaten varsa üzerine yazar.\"\"\"\n    for i in range(len(saved_x)):\n        if saved_x[i] == tx and saved_y[i] == ty:\n            saved_tiles[i] = tile_image\n            return\n    saved_x.append(tx)\n    saved_y.append(ty)\n    saved_tiles.append(tile_image)\n\ndef apply_saved_changes():\n    \"\"\"\n    level1 tilemap'i yeniden yüklendiğinde,\n    daha önce kaydedilen tüm tile değişikliklerini tekrar uygular.\n    \"\"\"\n    for i in range(len(saved_x)):\n        restored_loc = tiles.get_tile_location(saved_x[i], saved_y[i])\n        tiles.set_tile_at(restored_loc, saved_tiles[i])\n\n# ─────────────────────────────────────────\n# GLOBAL DEĞİŞKENLER\n# ─────────────────────────────────────────\nlastloc: tiles.Location = None\neditoron = False\ny = 0\nx = 0\nplayer2: Sprite = None\nvx = 0\nvy = 0\nloc: tiles.Location = None\npara = 1000\n\n# ─────────────────────────────────────────\n# B TUŞU — Builder menüsünü aç/kapat\n# ─────────────────────────────────────────\ndef on_b_pressed():\n    global x, y, loc, lastloc, editoron\n\n    x = Math.idiv(player2.x, 16)\n    y = Math.idiv(player2.y, 16)\n    loc = tiles.get_tile_location(x, y)\n    current_tile = tiles.get_tile_image(loc)\n\n    # --- ZONE tile üzerindeyse ---\n    if current_tile == assets.tile(\"\"\"\n        Zone\n        \"\"\"):\n        if not (editoron):\n            lastloc = loc\n            tiles.set_current_tilemap(tilemap(\"\"\"\n                Builder_menu\n                \"\"\"))\n            player2.set_position(75, 75)\n            editoron = True\n        else:\n            # level1'e geri dön\n            tiles.set_current_tilemap(tilemap(\"\"\"\n                level1\n                \"\"\"))\n            tiles.place_on_tile(player2, lastloc)\n\n            # lastloc'ta kayıtlı bir tile değişikliği yoksa Zone'u geri koy\n            already_saved = False\n            for i in range(len(saved_x)):\n                if saved_x[i] == x and saved_y[i] == y:\n                    already_saved = True\n            if not already_saved:\n                tiles.set_tile_at(lastloc, assets.tile(\"\"\"\n                    Zone\n                    \"\"\"))\n\n            # Kaydedilmiş tüm değişiklikleri yeniden uygula\n            apply_saved_changes()\n            editoron = False\n\n    # --- WINDMILL tile üzerindeyse ---\n    elif current_tile == assets.tile(\"\"\"\n        Windmill\n        \"\"\"):\n        if not (editoron):\n            lastloc = loc\n            tiles.set_current_tilemap(tilemap(\"\"\"\n                Builder_menu\n                \"\"\"))\n            player2.set_position(75, 75)\n            editoron = True\n        else:\n            tiles.set_current_tilemap(tilemap(\"\"\"\n                level1\n                \"\"\"))\n            tiles.place_on_tile(player2, lastloc)\n            apply_saved_changes()\n            editoron = False\n\n    # --- COAL_PLANT tile üzerindeyse ---\n    elif current_tile == assets.tile(\"\"\"\n        Coal_Plant\n        \"\"\"):\n        if not (editoron):\n            lastloc = loc\n            tiles.set_current_tilemap(tilemap(\"\"\"\n                Builder_menu\n                \"\"\"))\n            player2.set_position(75, 75)\n            editoron = True\n        else:\n            tiles.set_current_tilemap(tilemap(\"\"\"\n                level1\n                \"\"\"))\n            tiles.place_on_tile(player2, lastloc)\n            apply_saved_changes()\n            editoron = False\n\ncontroller.B.on_event(ControllerButtonEvent.PRESSED, on_b_pressed)\n\n# ─────────────────────────────────────────\n# A TUŞU — Tile hakkında bilgi göster\n# ─────────────────────────────────────────\ndef on_a_pressed():\n    global x, y, loc\n\n    x = Math.idiv(player2.x, 16)\n    y = Math.idiv(player2.y, 16)\n    loc = tiles.get_tile_location(x, y)\n    current_tile2 = tiles.get_tile_image(loc)\n\n    if current_tile2 == assets.tile(\"\"\"\n        Coal_Plant\n        \"\"\"):\n        game.show_long_text(\"Bu bir kömür santrali\", DialogLayout.BOTTOM)\n        game.show_long_text(\"Bu santral şehir için zararlı\", DialogLayout.BOTTOM)\n    elif current_tile2 == assets.tile(\"\"\"\n        Zone\n        \"\"\"):\n        game.show_long_text(\"Bu bir boş arazi\", DialogLayout.BOTTOM)\n        game.show_long_text(\"Buraya bir enerji santrali inşa edilebilir\",\n            DialogLayout.BOTTOM)\n    elif current_tile2 == assets.tile(\"\"\"\n        Windmill\n        \"\"\"):\n        game.show_long_text(\"Bu bir rüzgar türbini\", DialogLayout.BOTTOM)\n        game.show_long_text(\"Bu santral şehir için zararlı değil\", DialogLayout.BOTTOM)\n    elif current_tile2 == assets.tile(\"\"\"\n        Exit\n        \"\"\"):\n        game.show_long_text(\"Editörden çıkmak için \\\"B\\\" tuşuna bas\",\n            DialogLayout.CENTER)\n    else:\n        game.splash(\"Burayla işin yok!\")\n\ncontroller.A.on_event(ControllerButtonEvent.PRESSED, on_a_pressed)\n\n# ─────────────────────────────────────────\n# ÖRNEK: Builder menüsünde tile yerleştirme\n# (Kendi builder menü kodunla b